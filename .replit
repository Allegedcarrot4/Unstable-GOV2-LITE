run = "cowsay Configure me!"
entrypoint = "README.md"
modules = ["nodejs-20"]

[nix]
channel = "stable-24_11"
packages = ["cowsay", "wasmer"]

[agent]
expertMode = true

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Unstable Stealth Unified Server"

[[workflows.workflow]]
name = "Unstable Stealth Unified Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd app && npm install && npm start"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
deploymentTarget = "autoscale"
run = ["node", "Scramjet-App/src/index.js"]
